"use client";

import { useState, useRef, useEffect } from "react";
import MarkdownRenderer from "../components/MarkdownRenderer";
import Auth from "../components/Auth";
import { Send, Plus, MessageSquare, Menu, X, Paperclip, FileText, Image as ImageIcon, Loader2, LogOut } from "lucide-react";

export default function Home() {
  const [chats, setChats] = useState([]);
  const [currentChatId, setCurrentChatId] = useState(null);
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState("");
  const [isLoading, setIsLoading] = useState(false);
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [attachedFile, setAttachedFile] = useState(null); 
  const [isProcessingFile, setIsProcessingFile] = useState(false);
  const [isAuthVisible, setIsAuthVisible] = useState(true);
  const [user, setUser] = useState(null);
  const fileInputRef = useRef(null);
  const textareaRef = useRef(null);
  const messagesEndRef = useRef(null);
  const isRequestActive = useRef(false);
  const abortControllerRef = useRef(null);

  const getStorageKey = () => `chat_history_${user?.email || "guest"}`;

  // Load chats whenever the user changes
  useEffect(() => {
    const key = getStorageKey();
    const saved = localStorage.getItem(key);
    if (saved) {
      const parsed = JSON.parse(saved);
      setChats(parsed);
      if (parsed.length > 0) {
        setCurrentChatId(parsed[0].id);
        setMessages(parsed[0].messages);
      } else {
        setMessages([]);
        setCurrentChatId(null);
      }
    } else {
      setChats([]);
      setMessages([]);
      setCurrentChatId(null);
    }
  }, [user]);

  // Save current messages to the active chat in LocalStorage
  useEffect(() => {
    if (messages.length > 0 && currentChatId) {
      setChats(prev => {
        const exists = prev.find(c => c.id === currentChatId);
        if (!exists) return prev;
        const updated = prev.map(c => 
          c.id === currentChatId ? { ...c, messages, lastUpdated: Date.now() } : c
        );
        localStorage.setItem(getStorageKey(), JSON.stringify(updated));
        return updated;
      });
    }
  }, [messages, currentChatId, user]);

  const createNewChat = () => {
    const newId = Date.now().toString();
    const newChat = { id: newId, messages: [], lastUpdated: Date.now() };
    const updatedChats = [newChat, ...chats];
    setChats(updatedChats);
    setCurrentChatId(newId);
    setMessages([]);
    localStorage.setItem(getStorageKey(), JSON.stringify(updatedChats));
  };

  const deleteChat = (e, id) => {
    e.stopPropagation();
    const updated = chats.filter(c => c.id !== id);
    setChats(updated);
    localStorage.setItem(getStorageKey(), JSON.stringify(updated));
    if (currentChatId === id) {
      if (updated.length > 0) {
        setCurrentChatId(updated[0].id);
        setMessages(updated[0].messages);
      } else {
        createNewChat();
      }
    }
  };

  const selectChat = (chat) => {
    setCurrentChatId(chat.id);
    setMessages(chat.messages);
    setSidebarOpen(false);
  };

  // Auto-resize textarea
  useEffect(() => {
    if (textareaRef.current) {
      textareaRef.current.style.height = "auto";
      textareaRef.current.style.height = `${textareaRef.current.scrollHeight}px`;
    }
  }, [input]);

  // Scroll to bottom
  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages]);

  const handleFileUpload = async (e) => {
    const file = e.target.files[0];
    if (!file) return;

    setIsProcessingFile(true);
    
    try {
      if (file.type === "application/pdf" || file.type.startsWith("image/")) {
        const reader = new FileReader();
        const base64 = await new Promise((resolve) => {
          reader.onload = () => resolve(reader.result);
          reader.readAsDataURL(file);
        });
        setAttachedFile({ 
          name: file.name, 
          type: file.type === "application/pdf" ? "PDF" : "IMAGE", 
          content: "Raw media buffer captured.", 
          base64 
        });
      } 
      else {
        const content = await file.text();
        setAttachedFile({ name: file.name, type: "DOC", content: content.trim() });
      }
    } catch (err) {
      console.error("Scan Error:", err);
      alert("Failed to parse file.");
    } finally {
      setIsProcessingFile(false);
      e.target.value = ""; // clear input
    }
  };

  const handleSubmit = async (e) => {
    if (e) e.preventDefault();
    if (isRequestActive.current || (isLoading && !input.trim() && !attachedFile)) return;
    
    const currentInput = input.trim();
    if (!currentInput && !attachedFile) return;

    isRequestActive.current = true;
    setIsLoading(true);

    if (abortControllerRef.current) abortControllerRef.current.abort();
    abortControllerRef.current = new AbortController();

    // Prepare message for UI
    const displayMessage = { 
      role: "user", 
      content: attachedFile 
        ? `📄 [Scanned: ${attachedFile.name}]\n${currentInput}`
        : currentInput 
    };

    // Prepare payload for API
    let bodyPayload;
    if (attachedFile && attachedFile.type === "IMAGE") {
      bodyPayload = {
        messages: [
          ...messages,
          {
            role: "user",
            content: [
              { type: "text", text: currentInput || "Please describe and analyze this image." },
              { type: "image_url", image_url: { url: attachedFile.base64 } }
            ]
          }
        ]
      };
    } else {
      let finalPrompt = currentInput;
      if (attachedFile) {
        finalPrompt = `[SCANNED DOCUMENT: ${attachedFile.name}]\n${attachedFile.base64} \n---\nUser Query: ${currentInput || "Summarize this."}`;
      }
      bodyPayload = {
        messages: [...messages, { role: "user", content: finalPrompt }]
      };
    }

    setMessages(prev => [...prev, displayMessage]);
    setInput("");
    setAttachedFile(null);

    try {
      const response = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(bodyPayload),
        signal: abortControllerRef.current.signal,
      });

      if (!response.ok) throw new Error("Connection failed");

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let assistantText = "";

      setMessages(prev => [...prev, { role: "assistant", content: "" }]);

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        const chunk = decoder.decode(value);
        const lines = chunk.split("\n");

        for (const line of lines) {
          if (line.startsWith("data: ")) {
            const data = line.slice(6);
            if (data === "[DONE]") break;
            try {
              const { content } = JSON.parse(data);
              assistantText += content;
              setMessages(prev => {
                const updated = [...prev];
                updated[updated.length - 1].content = assistantText;
                return updated;
              });
            } catch (e) {}
          }
        }
      }
    } catch (err) {
      if (err.name !== "AbortError") {
        setMessages(prev => [...prev, { role: "assistant", content: "Error: Could not reach intelligence core." }]);
      }
    } finally {
      setIsLoading(false);
      isRequestActive.current = false;
    }
  };

  const handleKeyDown = (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      handleSubmit();
    }
  };

  const [mounted, setMounted] = useState(false);
  const [sessionTimestamp, setSessionTimestamp] = useState("");

  useEffect(() => {
    setMounted(true);
    setSessionTimestamp(new Date().toISOString().replace('T', '_').split('.')[0]);
  }, []);

  return (
    <div className="flex h-screen w-full bg-surface-container-lowest text-on-surface font-body overflow-hidden relative">
      {/* MECHANICAL OVERLAY */}
      <div className="fixed top-0 left-0 w-full h-full pointer-events-none z-0 opacity-[0.03]">
        <div className="w-full h-full" style={{ backgroundImage: "radial-gradient(#FFB59C 1px, transparent 0)", backgroundSize: "40px 40px" }}></div>
      </div>
      
      {sidebarOpen && (
        <div 
          className="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 md:hidden transition-all duration-300"
          onClick={() => setSidebarOpen(false)}
        />
      )}

      {/* Sidebar */}
      <div 
        className={`${
          sidebarOpen ? "translate-x-0" : "-translate-x-full"
        } md:translate-x-0 fixed md:static inset-y-0 left-0 z-50 w-[280px] bg-surface border-r border-outline-variant/20 shrink-0 flex flex-col p-4 transition-all duration-500 ease-in-out`}
      >
        <div className="flex items-center gap-2 mb-6 md:hidden">
          <button onClick={() => setSidebarOpen(false)} className="p-2 ml-auto text-gray-400 hover:text-white transition-colors">
            <X size={24} />
          </button>
        </div>

        <button 
          onClick={createNewChat} 
          className="flex items-center gap-3 p-3.5 bg-primary-container text-on-primary-container hover:translate-x-[-2px] hover:translate-y-[-2px] transition-all text-[11px] font-mono font-bold w-full uppercase shadow-lg active:scale-95 mb-6"
        >
          <span className="material-symbols-outlined scale-90" style={{ fontVariationSettings: "'FILL' 1" }}>add</span>
          New_Discussion
        </button>

        <div className="flex-1 overflow-y-auto mt-2 px-1 custom-scrollbar space-y-2">
          <div className="text-[10px] text-on-surface/40 font-mono font-bold uppercase tracking-[0.2em] mb-4 px-2">MEMORY_BANK</div>
          {chats.map((chat) => (
            <div key={chat.id} className="relative group">
              <button 
                onClick={() => selectChat(chat)}
                className={`flex items-center gap-3 p-3 w-full transition-all text-[12px] font-mono text-left truncate border ${
                  currentChatId === chat.id 
                  ? "bg-surface-container-high border-primary/30 text-primary" 
                  : "border-transparent text-on-surface/40 hover:bg-surface-container-low hover:text-on-surface"
                }`}
              >
                <span className="material-symbols-outlined scale-75" style={{ fontVariationSettings: currentChatId === chat.id ? "'FILL' 1" : "'FILL' 0" }}>
                  {currentChatId === chat.id ? "terminal" : "chat_bubble"}
                </span>
                <span className="truncate pr-8 font-medium uppercase tracking-tight">
                  {chat.messages.length > 0 ? chat.messages[0].content : "Empty_Session"}
                </span>
              </button>
              <button 
                onClick={(e) => deleteChat(e, chat.id)}
                className="absolute right-3 top-1/2 -translate-y-1/2 p-1 text-on-surface/20 hover:text-primary opacity-0 group-hover:opacity-100 transition-all"
              >
                <span className="material-symbols-outlined scale-75">close</span>
              </button>
            </div>
          ))}
        </div>

        <div className="p-4 mt-auto border-t border-outline-variant/10 bg-surface-container-lowest relative">
          <div 
            onClick={() => user ? null : setIsAuthVisible(true)}
            className="flex items-center gap-3 w-full cursor-pointer hover:bg-surface-container-high p-2 transition-colors group"
          >
            <div className={`w-9 h-9 bg-primary text-on-primary flex items-center justify-center shrink-0 font-headline font-bold shadow-lg group-hover:scale-105 transition-transform`}>
              {user ? user.name[0] : "U"}
            </div>
            <div className="flex flex-col min-w-0">
              <span className="text-[12px] font-mono font-bold truncate text-on-surface group-hover:text-primary transition-colors uppercase">
                {user ? user.name : "Session_User"}
              </span>
              <span className="text-[9px] text-on-surface/40 uppercase font-mono tracking-tighter">
                {user ? "Identity_Confirmed" : "Standard_Access"}
              </span>
            </div>
            {user && (
              <button 
                onClick={(e) => { e.stopPropagation(); setUser(null); }}
                className="ml-auto p-1.5 hover:bg-primary/10 text-on-surface/20 hover:text-primary transition-all"
                title="Logout"
              >
                <span className="material-symbols-outlined scale-75">logout</span>
              </button>
            )}
          </div>
        </div>
      </div>

      {isAuthVisible && (
        <Auth 
          onClose={() => setIsAuthVisible(false)} 
          onLogin={(userData) => setUser(userData)} 
          currentUser={user}
        />
      )}

      {/* Main Content */}
      <div className="flex-1 flex flex-col min-w-0 h-full relative z-0">
        <div className="sticky top-0 z-30 flex items-center justify-between p-4 bg-transparent backdrop-blur-md md:hidden text-white border-b border-white/5">
          <button onClick={() => setSidebarOpen(true)} className="p-2 -ml-2 hover:bg-white/5 rounded-xl transition-all active:scale-95">
            <Menu size={26} />
          </button>
          <div className="flex items-center gap-2">
             <div className="w-5 h-5 bg-gradient-to-br from-blue-500 to-emerald-400 rounded-md glow-logo" />
             <span className="font-black text-xs uppercase tracking-[0.3em] text-white/40">Interface</span>
          </div>
          <div className="w-10"></div>
        </div>

        <div className="flex-1 overflow-y-auto custom-scrollbar">
          {messages.length === 0 ? (
            <div className="h-full flex flex-col items-center justify-center p-8">
              <div className="relative w-28 h-28 mb-12">
                <div className="absolute inset-0 bg-primary/20 rounded-full blur-3xl animate-pulse" />
                <div className="relative w-full h-full bg-surface border border-outline-variant/20 rounded-[2rem] flex items-center justify-center shadow-2xl overflow-hidden group glow-logo">
                   <div className="w-12 h-12 bg-gradient-to-br from-primary via-primary-container to-primary rounded-xl" />
                </div>
              </div>
              <h1 className="text-4xl md:text-5xl font-headline font-black mb-4 tracking-tighter shimmer-text text-center uppercase">WELCOME TO AI Intelligence</h1>
              {mounted && (
                <div className="mt-8 font-mono text-[10px] text-on-surface/40 uppercase tracking-widest bg-surface px-4 py-1 border border-outline-variant/10">
                  Designed by Chiranjeeb Dash
                </div>
              )}
            </div>
          ) : (
            <div className="flex flex-col gap-6 mb-40 px-4 md:px-0 max-w-4xl mx-auto w-full">
              {messages.map((message, index) => (
                <div key={index} className={`w-full message-animate ${message.role === "user" ? "ml-auto max-w-3xl" : "max-w-4xl"}`}>
                  <div className="font-mono text-[11px] text-on-surface/30 mb-2 uppercase tracking-tighter">
                    {message.role === "user" ? `[SESSION_USR_01]` : `[STREAMING_DATA...]`}
                  </div>
                  
                  {message.role === "user" ? (
                    <div className="p-4 bg-surface-container-high border border-outline-variant/20 relative">
                      <div className="absolute -left-1 top-4 w-1 h-4 bg-primary"></div>
                      <p className="font-mono text-sm leading-relaxed text-on-surface/90">
                        <span className="text-outline font-bold mr-2">QUERY &gt;&gt;</span>
                        {message.content}
                      </p>
                    </div>
                  ) : (
                    <div className="p-4 bg-surface border border-outline-variant/10">
                      <div className="font-mono text-sm leading-relaxed text-on-surface/80">
                        <span className="text-primary-container font-bold mr-2">AXON &gt;&gt;</span>
                        {message.content ? (
                          <div className="inline-block prose prose-invert max-w-none prose-sm font-mono text-on-surface/80">
                            <MarkdownRenderer content={message.content} />
                          </div>
                        ) : (
                          <span className="inline-flex gap-1 items-center">
                            <span className="w-1.5 h-1.5 bg-primary animate-pulse"></span>
                            <span className="w-1.5 h-1.5 bg-primary animate-pulse delay-75"></span>
                            <span className="w-1.5 h-1.5 bg-primary animate-pulse delay-150"></span>
                          </span>
                        )}
                      </div>
                    </div>
                  )}
                </div>
              ))}
              <div ref={messagesEndRef} />
            </div>
          )}
        </div>

        {/* Terminal Input */}
        <div className="absolute bottom-0 left-0 w-full pt-16 pb-6 px-4 md:px-6 bg-gradient-to-t from-background via-background/95 to-transparent z-20">
          <form onSubmit={handleSubmit} className="mx-auto max-w-3xl">
            {(attachedFile || isProcessingFile) && (
              <div className="mb-3 flex items-center gap-3 p-4 bg-surface border border-outline-variant/20 animate-in slide-in-from-bottom-2 duration-300">
                <div className="w-12 h-12 bg-primary/10 border border-primary/20 flex items-center justify-center text-primary">
                  {isProcessingFile ? <Loader2 className="animate-spin" size={24} /> : (attachedFile.type === "IMAGE" ? <ImageIcon size={24} /> : <FileText size={24} />)}
                </div>
                <div className="flex-1 min-w-0">
                  <div className="text-[10px] font-mono uppercase tracking-widest text-on-surface/40 mb-0.5">Scanned_Media</div>
                  <div className="text-sm font-mono truncate text-on-surface">{isProcessingFile ? "Analyzing_Buffer..." : attachedFile.name}</div>
                </div>
                {!isProcessingFile && (
                  <button onClick={() => setAttachedFile(null)} className="p-2 hover:bg-on-surface/5 text-on-surface/40 hover:text-primary transition-all">
                    <X size={20} />
                  </button>
                )}
              </div>
            )}

            <div className="flex flex-col gap-2">
              <div className="flex items-center gap-4">
                <button type="button" onClick={() => fileInputRef.current?.click()} className="text-primary hover:scale-110 transition-transform">
                  <span className="material-symbols-outlined" style={{ fontVariationSettings: "'FILL' 1" }}>attach_file</span>
                </button>
                <input type="file" ref={fileInputRef} onChange={handleFileUpload} className="hidden" accept=".pdf,image/*,.txt,.md,.js,.json" />
                
                <div 
                  className="flex-grow flex items-start bg-surface px-4 py-3 border border-outline-variant/20 focus-within:border-primary transition-colors group relative cursor-text min-h-[48px]"
                  onClick={() => textareaRef.current?.focus()}
                >
                  <span className="font-mono text-xs text-primary-container font-bold mr-1 shrink-0 mt-[1px]">how may i assist you?</span>
                  
                  <div className="relative flex-grow min-h-[1.5rem] font-mono text-xs">
                    {/* Hidden Textarea for Input Handling */}
                    <textarea
                      ref={textareaRef}
                      value={input}
                      onChange={(e) => setInput(e.target.value)}
                      onKeyDown={handleKeyDown}
                      placeholder={input ? "" : "AWAITING_INPUT..."}
                      className="absolute inset-0 w-full h-full opacity-0 z-10 font-mono text-xs cursor-text resize-none bg-transparent border-0 ring-0 focus:ring-0 outline-none p-0"
                      rows={1}
                    />
                    
                    {/* Visual Mirror & Dynamic Cursor */}
                    <div className="w-full break-all whitespace-pre-wrap text-on-surface pointer-events-none flex flex-wrap items-center">
                      <span>{input}</span>
                      <span className="w-2 h-4 bg-primary cursor-blink shrink-0 ml-0.5" />
                    </div>
                  </div>
                </div>

                <button
                  type="submit"
                  disabled={(!input.trim() && !attachedFile) || isLoading}
                  className={`bg-primary-container text-on-primary-container font-mono text-[10px] font-bold px-6 py-3 uppercase transition-all active:scale-95 ${
                    (input.trim() || attachedFile) && !isLoading ? "opacity-100 hover:translate-x-[-2px] hover:translate-y-[-2px]" : "opacity-30 cursor-not-allowed"
                  }`}
                >
                  {isLoading ? "PROCS..." : "EXECUTE"}
                </button>
              </div>
              <div className="flex justify-between px-1">
                <span className="font-mono text-[8px] text-on-surface/30 uppercase">Command_Prompt_Active</span>
                <span className="font-mono text-[8px] text-on-surface/30 uppercase tracking-widest">Input_Buffer: {input.length}KB</span>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  );
}
