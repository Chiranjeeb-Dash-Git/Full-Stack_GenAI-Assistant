@tailwind base;
@tailwind components;
@tailwind utilities;

@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;900&family=Inter:wght@400;500;600&family=Space+Mono&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap');

@layer base {
  :root {
    --primary: 255 181 156;
    --surface: 19 19 19;
    --background: 14 14 14;
    --on-surface: 229 226 225;
  }
  body {
    background: #030406;
    color: #ececf1;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
    position: relative;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: 
      radial-gradient(circle at 2px 2px, rgba(255,255,255,0.03) 1px, transparent 0);
    background-size: 40px 40px;
    z-index: -1;
    pointer-events: none;
  }
}

@layer components {
  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    z-index: -2;
    opacity: 0.15;
    animation: float-slow 30s infinite alternate ease-in-out;
  }

  .orb-1 { width: 700px; height: 700px; background: #2563eb; top: -200px; right: -100px; }
  .orb-2 { width: 500px; height: 500px; background: #7c3aed; bottom: -100px; left: -100px; animation-delay: -5s; }
  .orb-3 { width: 400px; height: 400px; background: #059669; top: 30%; right: 20%; animation-delay: -15s; opacity: 0.05; }

  .glass-3 {
    background: rgba(10, 11, 13, 0.75);
    backdrop-filter: blur(40px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .glass-sidebar {
    background: rgba(6, 7, 8, 0.9);
    backdrop-filter: blur(30px);
    border-right: 1px solid rgba(255, 255, 255, 0.04);
  }

  .message-assistant {
    background: rgba(20, 21, 25, 0.4);
    backdrop-filter: blur(20px);
    position: relative;
    border-bottom: 1px solid rgba(255, 255, 255, 0.02);
  }

  .premium-bubble-ai {
    background: linear-gradient(90deg, rgba(37, 99, 235, 0.05) 0%, transparent 100%);
    border-left: 2px solid #2563eb;
  }

  .premium-button {
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 20px rgba(37, 99, 235, 0.3);
  }

  .premium-button:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 10px 30px rgba(37, 99, 235, 0.5);
    filter: brightness(1.2);
  }

  .input-container {
    background: rgba(14, 15, 18, 0.85);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 15px 45px rgba(0, 0, 0, 0.6);
  }

  .floating {
    animation: float-mini 4s infinite ease-in-out;
  }
}

@keyframes float-slow {
  0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
  33% { transform: translate(40px, -60px) rotate(5deg) scale(1.1); }
  66% { transform: translate(-30px, 40px) rotate(-5deg) scale(0.95); }
}

@keyframes float-mini {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes glowPulse {
  0%, 100% { box-shadow: 0 0 20px rgba(37, 99, 235, 0.4); transform: scale(1); }
  50% { box-shadow: 0 0 45px rgba(37, 99, 235, 0.7); transform: scale(1.05); }
}

.message-animate {
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.glow-logo {
  animation: glowPulse 4s infinite ease-in-out;
}

.shimmer-text {
  background: linear-gradient(90deg, #444, #fff, #444);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  animation: shimmer 4s infinite linear;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Robotic Aesthetic Animations */
@keyframes scan {
  0% { transform: translateY(-100%); opacity: 0; }
  50% { opacity: 1; }
  100% { transform: translateY(400%); opacity: 0; }
}

@keyframes shiver {
  0% { transform: translateX(0); }
  25% { transform: translateX(1px); }
  50% { transform: translateX(-1px); }
  75% { transform: translateX(1px); }
  100% { transform: translateX(0); }
}

@keyframes glitch {
  0% { text-shadow: 2px 0 #00fff9, -2px 0 #ff00c1; }
  25% { text-shadow: -2px 0 #00fff9, 2px 0 #ff00c1; }
  50% { text-shadow: 2px 2px #00fff9, -2px -2px #ff00c1; }
  75% { text-shadow: -2px -2px #00fff9, 2px 2px #ff00c1; }
  100% { text-shadow: 2px 0 #00fff9, -2px 0 #ff00c1; }
}

.animate-scan {
  animation: scan 3s linear infinite;
}

.glitch-text {
  animation: glitch 0.5s infinite alternate;
}

.animate-shiver {
  animation: shiver 0.2s infinite;
}

.circuit-bg {
  background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M10 10h80v80h-80z' fill='none' stroke='%23ffffff10' stroke-width='0.5'/%3E%3Ccircle cx='10' cy='10' r='1' fill='%23ffffff20'/%3E%3Ccircle cx='90' cy='10' r='1' fill='%23ffffff20'/%3E%3Ccircle cx='10' cy='90' r='1' fill='%23ffffff20'/%3E%3Ccircle cx='90' cy='90' r='1' fill='%23ffffff20'/%3E%3Cpath d='M10 50h20M80 50h10M50 10v20M50 80v10' stroke='%23ffffff15' stroke-width='0.5'/%3E%3C/svg%3E");
}

/* Ultra Advanced Buttons */
@keyframes glitch-skew {
  0% { transform: skew(0deg); }
  20% { transform: skew(2deg); }
  40% { transform: skew(-2deg); }
  60% { transform: skew(1deg); }
  80% { transform: skew(-1deg); }
  100% { transform: skew(0deg); }
}

.btn-ultra {
  position: relative;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1px solid rgba(59, 130, 246, 0.4);
  background: rgba(59, 130, 246, 0.05);
  clip-path: polygon(10% 0, 100% 0, 100% 70%, 90% 100%, 0 100%, 0 30%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  cursor: pointer;
}

.btn-ultra::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.1),
    transparent
  );
  transition: 0.6s;
}

.btn-ultra::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(59, 130, 246, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(59, 130, 246, 0.1) 1px, transparent 1px);
  background-size: 4px 4px;
  opacity: 0;
  transition: 0.3s;
}

.btn-ultra:hover::before {
  left: 100%;
}

.btn-ultra:hover::after {
  opacity: 1;
}

.btn-ultra:hover {
  border-color: #3b82f6;
  box-shadow: 0 0 40px rgba(59, 130, 246, 0.4), inset 0 0 20px rgba(59, 130, 246, 0.2);
  transform: scale(1.02);
  color: white;
}

.btn-ultra:active {
  animation: glitch-skew 0.1s infinite;
}

.btn-ultra-red {
  border-color: rgba(239, 68, 68, 0.4);
  background: rgba(239, 68, 68, 0.05);
  clip-path: polygon(0 0, 90% 0, 100% 30%, 100% 100%, 10% 100%, 0 70%);
}

.btn-ultra-red::after {
  background-image: 
    linear-gradient(rgba(239, 68, 68, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(239, 68, 68, 0.1) 1px, transparent 1px);
}

.btn-ultra-red:hover {
  border-color: #ef4444;
  box-shadow: 0 0 40px rgba(239, 68, 68, 0.4), inset 0 0 20px rgba(239, 68, 68, 0.2);
}

@keyframes neural-pulse {
  0%, 100% { opacity: 0.5; text-shadow: 0 0 5px rgba(59, 130, 246, 0.5); }
  50% { opacity: 1; text-shadow: 0 0 15px rgba(59, 130, 246, 1); }
}

.text-neural-pulse {
  animation: neural-pulse 2s infinite ease-in-out;
}

.link-tactical {
  transition: all 0.3s ease;
  position: relative;
}

.link-tactical::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, #3b82f6, transparent);
  transition: 0.3s;
}

.link-tactical:hover::after {
  width: 100%;
}

.custom-scrollbar::-webkit-scrollbar {
  width: 4px;
}
.custom-scrollbar::-webkit-scrollbar-track {
  background: #0e0e0e;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
  background: #353534;
}
.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: #ffb59c;
}

.cursor-blink {
  animation: blink 1s step-end infinite;
}
@keyframes blink {
  50% {
    opacity: 0;
  }
}
.mechanical-hover:hover {
  transform: translate(-2px, -2px);
}

.font-headline {
  font-family: 'Space Grotesk', sans-serif;
}
.font-body {
  font-family: 'Inter', sans-serif;
}
.font-label {
  font-family: 'Space Grotesk', sans-serif;
}
.font-mono {
  font-family: 'Space Mono', monospace;
}
